# Supabase
NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Database (for Prisma)
# ✅ استخدم Session Pooler (port 6543) للتطوير والإنتاج
# ❌ لا تستخدم Direct Connection (port 5432) إلا للـ migrations
DATABASE_URL=postgresql://postgres.xxx:password@aws-1-ap-south-1.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require

# Next.js
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: File Upload
NEXT_PUBLIC_SUPABASE_STORAGE_BUCKET=media

# Optional: Prisma Logging (للتطوير فقط)
# PRISMA_LOG_QUERIES=true

